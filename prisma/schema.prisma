generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PipelineEntry {
  id           Int       @id @default(autoincrement())
  clientName   String
  description  String?
  amount       Float
  expectedDate DateTime?
  isRecurring  Boolean   @default(false)
  frequency    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
